# MySQL Configuration
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here

# Optional: Override default MySQL connection settings
# MYSQL_HOST=host.docker.internal
# MYSQL_PORT=3306
# MYSQL_DATABASE=mist

# Docker Deployment Configuration
# REPO_OWNER=your-github-username  # Default: moyui
# VERSION=latest                    # Or specific version: v1.0.0

# Application Environment
# NODE_ENV=production              # Default: production

# AKTools Configuration (auto-configured, usually don't need to change)
# AKTOOLS_BASE_URL=http://aktools:8080
