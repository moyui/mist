# ===== Node Environment =====
NODE_ENV=development

# ===== MySQL =====
mysql_server_host=localhost
mysql_server_port=3306
mysql_server_username=root
mysql_server_password=your_password_here
mysql_server_database=mist

# ===== Redis =====
redis_server_host=localhost
redis_server_port=6379
redis_server_db=0

# ===== Data Source =====
# ef=EastMoney, tdx=TongDaXin, mqmt=MaQiMaTe
DEFAULT_DATA_SOURCE=tdx

# TDX Data Source Configuration
# Base URL for mist-datasource service (TongDaXin bridge)
# Local development: http://127.0.0.1:9001
# Production: set to actual mist-datasource service URL
TDX_BASE_URL=http://127.0.0.1:9001

# WebSocket client identification for mist-datasource
# Used to identify this client in the WebSocket path: /ws/quote/{client_id}
# Each data source (TDX, miniQMT) has its own WebSocket connection with unique client_id
# This allows multiple concurrent WebSocket connections from the same backend
TDX_WS_CLIENT_ID=mist-backend-tdx
QMT_WS_CLIENT_ID=mist-backend-qmt

# ===== AKTools =====
AKTOOLS_BASE_URL=http://localhost:8080

# ===== App Ports =====
# Ports are NOT set in shared .env. Each app uses its hardcoded default
# in main.ts (process.env.PORT ?? <default>). Docker overrides per-service
# via docker-compose.yml environment section.
# To override locally, set PORT env var when starting: PORT=8002 pnpm run start:dev:saya

# ===== LLM (saya only) =====
REASONING_API_KEY=
REASONING_BASE_URL=
REASONING_MODEL=
FAST_API_KEY=
FAST_BASE_URL=
FAST_MODEL=
VL_API_KEY=
VL_BASE_URL=
VL_MODEL=
TAVILY_API_KEY=

# ===== Saya Settings =====
DEBUG=false
APP_ENV=development

# ===== Docker Deployment =====
REPO_OWNER=moyui
VERSION=latest
